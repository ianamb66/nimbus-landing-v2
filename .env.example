# Email leads (Resend)
# 1) Crea una cuenta en https://resend.com
# 2) Genera un API Key
# 3) (Opcional) Verifica tu dominio para usar un remitente @nimbus.mx
RESEND_API_KEY=
LEADS_TO_EMAIL=ian@nimbus.mx
# Si no verificas dominio en Resend, puedes usar: onboarding@resend.dev
LEADS_FROM_EMAIL=onboarding@resend.dev

# ---
# Google Sheets (Apps Script Webhook) [opcional]
# Crea un Apps Script como Web App que reciba POST y agregue una fila.
GOOGLE_SHEETS_WEBHOOK_URL=
# Opcional: token simple para evitar spam (se valida en Apps Script)
GOOGLE_SHEETS_WEBHOOK_TOKEN=
